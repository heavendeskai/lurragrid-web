---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogTitle?: string;
}

const {
  title,
  description = 'LurraGrid converts abandoned hard rock mines into firm, dispatchable underground power infrastructure for AI compute.',
  ogTitle,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={ogTitle || title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="LurraGrid" />
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  
  <!-- Fonts preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body class="bg-void text-frost">
  <slot />
  
  <script>
    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Mobile: touch card orange top bar reveal
    if (window.matchMedia('(hover: none)').matches) {
      document.querySelectorAll('.group').forEach(card => {
        card.addEventListener('touchstart', () => {
          const bar = card.querySelector('.scale-x-0');
          if (bar) { bar.style.transform = 'scaleX(1)'; bar.style.transition = 'transform 0.3s ease'; }
        }, { passive: true });
        card.addEventListener('touchend', () => {
          setTimeout(() => {
            const bar = card.querySelector('.scale-x-0, [style*="scaleX"]');
            if (bar) { bar.style.transform = ''; }
          }, 600);
        }, { passive: true });
      });
    }

    // Stat bar grow on scroll
    const statObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          statObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.3 });
    document.querySelectorAll('.stat-bar-animate').forEach((el, i) => {
      el.classList.add(`stat-bar-${(i % 3) + 1}`);
      statObserver.observe(el);
    });

    // Municipality parallax
    const parallaxImg = document.querySelector('.hero-parallax');
    if (parallaxImg) {
      window.addEventListener('scroll', () => {
        const scrolled = window.scrollY;
        const pos = 50 + (scrolled * 0.015);
        parallaxImg.style.objectPosition = `center ${Math.min(pos, 60)}%`;
      }, { passive: true });
    }

    // Nav scroll behavior
    const nav = document.querySelector('nav');
    if (nav) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 60) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }
      });
    }
  </script>
</body>
</html>
