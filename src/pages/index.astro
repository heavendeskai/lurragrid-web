---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroSVG from '../components/HeroSVG.astro';
---

<Base title="LurraGrid — Powering the AI Era from the Ground Down">
  <Nav />

<!-- HERO -->
  <section class="hero-section min-h-screen relative flex items-center overflow-hidden">
    <!-- Background subtle geological grid texture -->
    <div class="hero-bg absolute inset-0 pointer-events-none"></div>
    <!-- Blue glow from below suggests underground depth -->
    <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-full h-64 pointer-events-none" style="background: radial-gradient(ellipse 80% 100% at 50% 100%, rgba(0,68,170,0.18) 0%, transparent 70%);"></div>
    <!-- Horizontal rule at surface level -->
    <div class="absolute top-[42%] left-0 right-0 h-px pointer-events-none" style="background: linear-gradient(90deg, transparent, rgba(0,68,170,0.25) 20%, rgba(0,85,204,0.4) 50%, rgba(0,68,170,0.25) 80%, transparent);"></div>

    <!-- Full-width content grid -->
    <div class="relative w-full px-12 md:px-20 pt-32 pb-20">
      <div class="grid grid-cols-12 gap-6 items-center min-h-[80vh]">

        <!-- Left text: cols 1-6 -->
        <div class="col-span-12 md:col-span-6 lg:col-span-5">
          <p class="font-body text-xs tracking-[0.35em] uppercase text-royal mb-8 animate-fade-up">
            Underground Pumped Hydro Storage
          </p>
          <h1 class="font-display font-bold text-5xl md:text-6xl lg:text-7xl leading-[0.95] text-frost mb-8 animate-fade-up-delay-1">
            POWERING<br/>THE AI ERA<br/><span style="color:#0044AA">FROM THE</span><br/>GROUND DOWN.
          </h1>
          <p class="font-body text-base md:text-lg text-frost-dim leading-relaxed mb-10 max-w-lg animate-fade-up-delay-2">
            We convert abandoned hard rock mines into firm, dispatchable underground power infrastructure for AI compute — delivered directly behind the meter.
          </p>
          <div class="flex flex-wrap gap-4 animate-fade-up-delay-3">
            <a
              href="/contact"
              class="font-display font-bold text-sm tracking-widest uppercase px-8 py-4 bg-royal text-frost hover:bg-royal-light transition-colors duration-300"
            >
              Partner Inquiries
            </a>
            <a
              href="/platform"
              class="font-display font-bold text-sm tracking-widest uppercase px-8 py-4 border border-frost-dim text-frost-dim hover:text-frost hover:border-frost transition-colors duration-300"
            >
              The Technology
            </a>
          </div>

          <!-- Stats strip -->
          <div class="grid grid-cols-3 gap-6 mt-16 pt-10 border-t border-rule animate-fade-up-delay-3">
            <div>
              <p class="font-display font-bold text-3xl text-frost">950</p>
              <p class="font-body text-xs text-frost-dim tracking-widest uppercase mt-1">Pre-Screened Sites</p>
            </div>
            <div>
              <p class="font-display font-bold text-3xl text-frost">15</p>
              <p class="font-body text-xs text-frost-dim tracking-widest uppercase mt-1">States</p>
            </div>
            <div>
              <p class="font-display font-bold text-3xl text-frost">50yr</p>
              <p class="font-body text-xs text-frost-dim tracking-widest uppercase mt-1">Asset Life</p>
            </div>
          </div>
        </div>

        <!-- Right SVG: cols 7-12 -->
        <div class="col-span-12 md:col-span-6 lg:col-span-7 flex items-center justify-center lg:justify-end">
          <div class="w-full max-w-2xl lg:max-w-none">
            <HeroSVG />
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="border-t border-rule mx-8 md:mx-12"></div>

  <!-- THESIS -->
  <section class="py-32 px-8 md:px-12 max-w-4xl mx-auto reveal">
    <p class="font-body text-xs tracking-[0.3em] uppercase text-royal mb-8">The Problem We Solve</p>
    <p class="font-display font-bold text-2xl md:text-3xl text-frost leading-snug">
      AI compute demand is outpacing the grid. Interconnection queues run five to seven years. ESG mandates restrict gas. LurraGrid converts existing underground infrastructure into firm, behind-the-meter power for hyperscale operators — delivered faster than the grid can build.
    </p>
  </section>

  <!-- ARCHITECTURE CARDS -->
  <section class="py-20 px-8 md:px-12 max-w-7xl mx-auto">
    <div class="reveal mb-16">
      <p class="font-body text-xs tracking-[0.3em] uppercase text-royal mb-4">The Architecture</p>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-frost">Three Layers. One Platform.</h2>
    </div>
    
    <div class="grid md:grid-cols-3 gap-px bg-rule reveal">
      <!-- LurraCore -->
      <div class="bg-void p-10 hover:bg-rule transition-colors duration-500 group">
        <div class="w-10 h-10 border border-royal flex items-center justify-center mb-6 group-hover:bg-royal transition-colors duration-300">
          <span class="font-display font-bold text-xs text-royal group-hover:text-frost">01</span>
        </div>
        <h3 class="font-display font-bold text-xl text-frost mb-3">LurraCore</h3>
        <p class="font-body text-sm text-royal uppercase tracking-widest mb-4">Underground Storage &amp; Dispatch</p>
        <p class="font-body text-sm text-frost-dim leading-relaxed">
          The mine is the battery. Existing hard rock shafts and cavities become upper and lower reservoirs, storing energy as potential head. No new excavation. No new permitting. The infrastructure already exists.
        </p>
      </div>

      <!-- LurraCascade -->
      <div class="bg-void p-10 hover:bg-rule transition-colors duration-500 group">
        <div class="w-10 h-10 border border-royal flex items-center justify-center mb-6 group-hover:bg-royal transition-colors duration-300">
          <span class="font-display font-bold text-xs text-royal group-hover:text-frost">02</span>
        </div>
        <h3 class="font-display font-bold text-xl text-frost mb-3">LurraCascade</h3>
        <p class="font-body text-sm text-royal uppercase tracking-widest mb-4">Patent-Pending Continuity System</p>
        <p class="font-body text-sm text-frost-dim leading-relaxed">
          Dual-reservoir threshold switching maintains uninterrupted power delivery. Automated actuators engage at 20% reservoir threshold, seamlessly transitioning between cascade stages. Patent pending, prior art published CERN Zenodo May 2026.
        </p>
      </div>

      <!-- LurraCharge -->
      <div class="bg-void p-10 hover:bg-rule transition-colors duration-500 group">
        <div class="w-10 h-10 border border-royal flex items-center justify-center mb-6 group-hover:bg-royal transition-colors duration-300">
          <span class="font-display font-bold text-xs text-royal group-hover:text-frost">03</span>
        </div>
        <h3 class="font-display font-bold text-xl text-frost mb-3">LurraCharge</h3>
        <p class="font-body text-sm text-royal uppercase tracking-widest mb-4">Curtailed Energy Recharge Layer</p>
        <p class="font-body text-sm text-frost-dim leading-relaxed">
          Recharges overnight on curtailed wind and off-peak grid power — energy the market cannot absorb. The arbitrage spread between curtailed input and firm daytime output is the business model.
        </p>
      </div>
    </div>

    <div class="mt-8 reveal">
      <a href="/platform" class="font-body text-sm tracking-widest uppercase text-royal hover:text-royal-light transition-colors duration-300">
        Full Platform Architecture →
      </a>
    </div>
  </section>

  <!-- THREE LURRANODES -->
  <section class="py-20 px-8 md:px-12 max-w-7xl mx-auto">
    <div class="reveal mb-16">
      <p class="font-body text-xs tracking-[0.3em] uppercase text-royal mb-4">The Portfolio</p>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-frost">Three LurraNodes.</h2>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8 reveal">
      <!-- Node 001 -->
      <div class="border border-rule p-8 relative overflow-hidden group hover:border-royal transition-colors duration-500">
        <div class="absolute top-0 left-0 w-full h-0.5 bg-royal scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
        <p class="font-body text-xs tracking-[0.25em] uppercase text-royal mb-2">LurraNode 001</p>
        <h3 class="font-display font-bold text-2xl text-frost mb-1">Mather B</h3>
        <p class="font-body text-sm text-frost-dim mb-4">Negaunee, Michigan · Hard Rock Iron Ore</p>
        <div class="border-t border-rule pt-4 mt-4">
          <p class="font-body text-xs text-frost-dim">Depth: 3,500 ft · Phase 1 Anchor Site</p>
          <p class="font-body text-xs text-frost-dim mt-1">Asset life: 50 years</p>
        </div>
        <div class="mt-4">
          <span class="inline-block text-xs tracking-widest uppercase border border-royal text-royal px-3 py-1">Active</span>
        </div>
      </div>

      <!-- Node 002 -->
      <div class="border border-rule p-8 relative overflow-hidden group hover:border-royal transition-colors duration-500">
        <div class="absolute top-0 left-0 w-full h-0.5 bg-royal scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
        <p class="font-body text-xs tracking-[0.25em] uppercase text-royal mb-2">LurraNode 002</p>
        <h3 class="font-display font-bold text-2xl text-frost mb-1">Quincy</h3>
        <p class="font-body text-sm text-frost-dim mb-4">Hancock, Michigan · Hard Rock Copper</p>
        <div class="border-t border-rule pt-4 mt-4">
          <p class="font-body text-xs text-frost-dim">Depth: 6,200 ft · World Record Depth</p>
          <p class="font-body text-xs text-frost-dim mt-1">Phase 2</p>
        </div>
        <div class="mt-4">
          <span class="inline-block text-xs tracking-widest uppercase border border-rule text-frost-dim px-3 py-1">Phase 2</span>
        </div>
      </div>

      <!-- Node 003 -->
      <div class="border border-rule p-8 relative overflow-hidden group hover:border-royal transition-colors duration-500">
        <div class="absolute top-0 left-0 w-full h-0.5 bg-royal scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
        <p class="font-body text-xs tracking-[0.25em] uppercase text-royal mb-2">LurraNode 003</p>
        <h3 class="font-display font-bold text-2xl text-frost mb-1">Comstock</h3>
        <p class="font-body text-sm text-frost-dim mb-4">Virginia City, Nevada · Silver &amp; Gold</p>
        <div class="border-t border-rule pt-4 mt-4">
          <p class="font-body text-xs text-frost-dim">Depth: 3,360 ft · Reno Data Center Corridor</p>
          <p class="font-body text-xs text-frost-dim mt-1">Phase 3</p>
        </div>
        <div class="mt-4">
          <span class="inline-block text-xs tracking-widest uppercase border border-rule text-frost-dim px-3 py-1">Phase 3</span>
        </div>
      </div>
    </div>

    <div class="mt-8 reveal">
      <a href="/sites" class="font-body text-sm tracking-widest uppercase text-royal hover:text-royal-light transition-colors duration-300">
        View All Sites →
      </a>
    </div>
  </section>

  <!-- RESEARCH FOUNDATION -->
  <section class="py-32 px-8 md:px-12 max-w-7xl mx-auto reveal">
    <div class="border border-rule p-12 md:p-16">
      <p class="font-body text-xs tracking-[0.3em] uppercase text-royal mb-6">Peer-Reviewed Foundation</p>
      <h2 class="font-display font-bold text-2xl md:text-3xl text-frost mb-6 max-w-2xl">
        Three years of peer-reviewed academic research. One patent-pending continuity system. One platform.
      </h2>
      <p class="font-body text-sm text-frost-dim leading-relaxed max-w-2xl mb-8">
        Built on foundational research conducted at Michigan Technological University under the MTU PUSH program, funded by the Alfred P. Sloan Foundation. The LurraCascade Continuity System was published as prior art on CERN Zenodo, May 5, 2026.
      </p>
      <div class="flex flex-col sm:flex-row gap-6">
        <a href="/research" class="font-body text-sm tracking-widest uppercase text-royal hover:text-royal-light transition-colors duration-300">
          Research Foundation →
        </a>
        <a
          href="https://zenodo.org/doi/10.5281/zenodo.20045602"
          target="_blank"
          rel="noopener noreferrer"
          class="font-body text-sm tracking-widest uppercase text-frost-dim hover:text-frost transition-colors duration-300"
        >
          DOI 10.5281/zenodo.20045602 ↗
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 px-8 md:px-12 text-center max-w-3xl mx-auto reveal">
    <h2 class="font-display font-bold text-4xl md:text-5xl text-frost mb-6">
      Ready to build firm power infrastructure for the AI era?
    </h2>
    <p class="font-body text-lg text-frost-dim mb-10">
      We are accepting partner inquiries from data center operators, municipal owners, EPC firms, and institutional investors.
    </p>
    <a
      href="/contact"
      class="inline-block font-display font-bold text-sm tracking-widest uppercase px-10 py-4 bg-royal text-frost hover:bg-royal-light transition-colors duration-300"
    >
      Start a Conversation
    </a>
  </section>

  <Footer />
</Base>
