---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Base
  title="Contact — LurraGrid"
  description="Partner inquiries: municipal partners, data center operators, EPC firms, investors, and academic collaborators."
>
  <Nav />

  <!-- Hero -->
  <section class="min-h-[40vh] flex flex-col justify-end px-8 md:px-12 pt-40 pb-20 max-w-5xl mx-auto">
    <p class="font-body text-xs tracking-[0.3em] uppercase text-royal mb-6 animate-fade-up">Get in Touch</p>
    <h1 class="font-display font-bold text-5xl md:text-7xl text-frost leading-none mb-6 animate-fade-up-delay-1">
      PARTNER INQUIRIES.
    </h1>
    <p class="font-body text-lg text-frost-dim max-w-xl leading-relaxed animate-fade-up-delay-2">
      We are accepting inquiries from data center operators, municipal mine owners, EPC partners, institutional investors, and academic collaborators.
    </p>
  </section>

  <div class="border-t border-rule mx-8 md:mx-12"></div>

  <!-- Form -->
  <section class="py-24 px-8 md:px-12 max-w-7xl mx-auto reveal">
    <div class="grid md:grid-cols-12 gap-12">
      <!-- Form -->
      <div class="md:col-span-7">
        <form
          name="partner-inquiry"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          class="space-y-6"
        >
          <!-- Netlify hidden field -->
          <input type="hidden" name="form-name" value="partner-inquiry" />
          <p class="hidden">
            <label>Don't fill this out: <input name="bot-field" /></label>
          </p>

          <!-- Name -->
          <div class="space-y-2">
            <label for="name" class="font-body text-xs tracking-widest uppercase text-frost-dim block">
              Name *
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full bg-void border border-rule text-frost font-body text-sm px-4 py-3 focus:outline-none focus:border-royal transition-colors duration-300 placeholder-rule"
              placeholder="Your full name"
            />
          </div>

          <!-- Organization -->
          <div class="space-y-2">
            <label for="organization" class="font-body text-xs tracking-widest uppercase text-frost-dim block">
              Organization
            </label>
            <input
              type="text"
              id="organization"
              name="organization"
              class="w-full bg-void border border-rule text-frost font-body text-sm px-4 py-3 focus:outline-none focus:border-royal transition-colors duration-300 placeholder-rule"
              placeholder="Company or institution"
            />
          </div>

          <!-- Email -->
          <div class="space-y-2">
            <label for="email" class="font-body text-xs tracking-widest uppercase text-frost-dim block">
              Email *
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-void border border-rule text-frost font-body text-sm px-4 py-3 focus:outline-none focus:border-royal transition-colors duration-300 placeholder-rule"
              placeholder="your@organization.com"
            />
          </div>

          <!-- Inquiry Type -->
          <div class="space-y-2">
            <label for="inquiry-type" class="font-body text-xs tracking-widest uppercase text-frost-dim block">
              Inquiry Type *
            </label>
            <select
              id="inquiry-type"
              name="inquiry-type"
              required
              class="w-full bg-void border border-rule text-frost font-body text-sm px-4 py-3 focus:outline-none focus:border-royal transition-colors duration-300 appearance-none cursor-pointer"
            >
              <option value="" disabled selected>Select inquiry type</option>
              <option value="municipal-partner">Municipal Partner</option>
              <option value="data-center-operator">Data Center Operator</option>
              <option value="epc-partner">EPC Partner</option>
              <option value="institutional-investor">Institutional Investor</option>
              <option value="press">Press</option>
              <option value="academic-collaboration">Academic Collaboration</option>
              <option value="other">Other</option>
            </select>
          </div>

          <!-- Message -->
          <div class="space-y-2">
            <label for="message" class="font-body text-xs tracking-widest uppercase text-frost-dim block">
              Message *
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              class="w-full bg-void border border-rule text-frost font-body text-sm px-4 py-3 focus:outline-none focus:border-royal transition-colors duration-300 placeholder-rule resize-none"
              placeholder="Tell us about your interest or project"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full font-display font-bold text-sm tracking-widest uppercase py-4 bg-royal text-frost hover:bg-royal-light transition-colors duration-300"
          >
            Send Inquiry
          </button>
        </form>
      </div>

      <!-- Contact info -->
      <div class="md:col-span-4 md:col-start-9 space-y-10">
        <div>
          <p class="font-body text-xs tracking-widest uppercase text-royal mb-3">Response Time</p>
          <p class="font-body text-sm text-frost-dim">We respond to all partner inquiries within 2 business days.</p>
        </div>

        <div class="border-t border-rule pt-8">
          <p class="font-body text-xs tracking-widest uppercase text-frost-dim mb-4">Who We're Talking To</p>
          <ul class="space-y-3">
            {[
              'Municipal mine owners',
              'Data center operators',
              'EPC firms with shaft & submersible pump expertise',
              'Institutional investors',
              'Academic research collaborators',
              'Press and media',
            ].map(item => (
              <li class="flex gap-3 items-start">
                <span class="w-1 h-1 bg-royal block mt-2 shrink-0"></span>
                <span class="font-body text-sm text-frost-dim">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="border-t border-rule pt-8">
          <p class="font-body text-xs tracking-widest uppercase text-frost-dim mb-3">Note</p>
          <p class="font-body text-xs text-frost-dim leading-relaxed">
            LurraGrid does not accept unsolicited investment offers. All investment discussions occur through our formal process with appropriate disclosure documentation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Base>
