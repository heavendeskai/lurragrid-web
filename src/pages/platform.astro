---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const layers = [
  {
    num: '01',
    name: 'LurraCore',
    tag: 'Underground Storage & Dispatch',
    body: `The mine is the battery. Existing hard rock shafts and cavity networks become upper and lower reservoirs. Water flows from upper to lower through a turbine to generate power. Pumped back up overnight to recharge. No new excavation required. The civil engineering is already done — we commission it.`,
    detail: `Round-trip efficiency: 80%. Asset life: 50 years. Firm, dispatchable power delivered directly behind the meter to the data center load.`,
  },
  {
    num: '02',
    name: 'LurraCascade',
    tag: 'Patent-Pending Continuity System',
    body: `Conventional pumped hydro stops when the upper reservoir empties. LurraCascade eliminates that constraint. A dual-reservoir threshold switching system automatically engages a secondary cascade stage at 20% reservoir level, maintaining uninterrupted power delivery.`,
    detail: `Prior art published May 5, 2026, CERN Zenodo, DOI 10.5281/zenodo.20045602. USPTO provisional filing in process. Four independent claims: the method, the system, the BTM data center application, and the automated threshold actuator.`,
    patent: true,
  },
  {
    num: '03',
    name: 'LurraCharge',
    tag: 'Curtailed Energy Recharge Layer',
    body: `Wind and nuclear cannot throttle overnight. Grid operators log millions of megawatt-hours of curtailed generation annually — energy the market cannot absorb. LurraCharge acquires this energy at near-zero or negative cost through negotiated power purchase agreements. The recharge window is 8–10 hours overnight.`,
    detail: `MISO territory alone logs over 1.5 million MWh of curtailed wind annually. Negative LMP pricing events are documented and recurring.`,
  },
  {
    num: '04',
    name: 'LurraBridge',
    tag: 'Sub-100ms Frequency Response',
    body: `An EV battery bridge layer provides sub-100ms frequency response for grid interconnection requirements. LurraBridge handles the instantaneous demand while LurraCore ramps to full output — meeting both the speed of grid ancillary services and the endurance of a 14–16 hour dispatch window.`,
    detail: `Critical for BTM data center applications where uninterrupted power is a contractual requirement.`,
  },
  {
    num: '05',
    name: 'LurraPDA',
    tag: '20-Year Take-or-Pay Power Delivery Agreement',
    body: `LurraGrid delivers power under long-term Power Delivery Agreements — 20-year take-or-pay contracts negotiated directly with data center operators. The data center commits to taking minimum volumes. LurraGrid commits to firm delivery. Price certainty. Supply certainty. Infrastructure-grade contract structure.`,
    detail: `Structured as behind-the-meter delivery, avoiding grid interconnection queues. Project-level debt is secured against PDA cash flows — investors never personally guarantee construction debt.`,
  },
  {
    num: '06',
    name: 'LurraAtlas',
    tag: '950 Pre-Screened Sites Across 15 States',
    body: `Abandoned hard rock mines are not scarce. The United States holds thousands of them across the western and upper midwest mining belts. LurraAtlas is our proprietary site screening database: 950 sites evaluated across 15 states against head, depth, geometry, hydrogeology, transmission access, and proximity to data center demand corridors.`,
    detail: `Screening criteria include: minimum net head 300m, minimum depth 1,000 ft, suitable cavity geometry, proximity to transmission, and viable groundwater management pathway.`,
  },
];
---

<Base
  title="Platform — LurraGrid"
  description="The LurraGrid technology architecture: LurraCore, LurraCascade, LurraCharge, LurraBridge, LurraPDA, and LurraAtlas."
>
  <Nav />

  <!-- Hero — full bleed image -->
  <section class="relative min-h-[75vh] flex flex-col justify-end overflow-hidden">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img
        src="/platform-hero.jpg"
        alt="LurraCore underground control room"
        class="w-full h-full object-cover object-center hero-pan"
      />
      <!-- Dark overlay — void black at 65% so text pops and brand stays dominant -->
      <!-- Heavy top fade — protects nav -->
      <div class="absolute inset-0" style="background: linear-gradient(to bottom, rgba(0,0,0,0.90) 0%, rgba(0,0,0,0.50) 15%, rgba(0,0,0,0.15) 35%, transparent 55%);"></div>
      <!-- Bottom fade -->
      <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.97) 0%, rgba(0,0,0,0.75) 40%, transparent 65%);"></div>
      <!-- Royal blue tint layer — keeps it on-brand -->
      <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(0,20,60,0.35) 0%, transparent 60%);"></div>
    </div>

    <!-- Content over image -->
    <div class="relative px-6 md:px-12 pt-28 md:pt-48 pb-12 md:pb-24 max-w-5xl mx-auto w-full flex flex-col justify-center min-h-[60vh] md:min-h-[75vh]">
      <p class="font-body text-xs tracking-[0.3em] uppercase mb-6 animate-fade-up eyebrow-over-image">The Technology</p>
      <h1 class="font-display font-bold text-4xl sm:text-5xl md:text-7xl text-frost leading-none mb-6 animate-fade-up-delay-1">
        THE MINE IS<br />THE BATTERY.
      </h1>
      <p class="font-body text-lg text-frost-dim max-w-xl leading-relaxed animate-fade-up-delay-2">
        LurraGrid is an energy arbitrage platform: acquire curtailed renewables at near-zero cost, deliver firm dispatchable power at premium behind-the-meter rates. Six integrated layers. One platform.
      </p>
    </div>
  </section>

  <div class="border-t border-rule mx-8 md:mx-12"></div>

  <!-- DATA CENTER VALUE PROPOSITION -->
  <section class="py-20 md:py-28 px-6 md:px-12 w-full section-blue-deep">
    <div class="max-w-7xl mx-auto">

      <!-- Section header -->
      <div class="mb-16 max-w-3xl">
        <p class="font-body text-xs tracking-[0.3em] uppercase mb-4 eyebrow-over-image accent-line">Why Data Centers Choose LurraGrid</p>
        <h2 class="font-display font-bold text-3xl md:text-5xl text-frost leading-tight mb-6">
          Power ready when your racks are.
        </h2>
        <p class="font-body text-lg text-frost-dim leading-relaxed">
          The grid cannot serve you on your timeline. LurraGrid can. We built the entire model around the data center development cycle.
        </p>
      </div>

      <!-- 5 value prop blocks -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-px bg-rule">

        <!-- 1 -->
        <div class="bg-void p-8 md:p-10">
          <div class="w-10 h-1 mb-6" style="background: linear-gradient(90deg, #FF6600, #0044AA);"></div>
          <h3 class="font-display font-bold text-xl text-frost mb-3">The Grid Can't Serve You</h3>
          <p class="font-body text-sm text-frost-dim leading-relaxed">
            Interconnection queues run five to seven years. ESG mandates restrict gas. By the time the grid catches up to your load, your facility has been dark for years. You need power on your schedule — not the utility's.
          </p>
        </div>

        <!-- 2 -->
        <div class="bg-void p-8 md:p-10">
          <div class="w-10 h-1 mb-6" style="background: linear-gradient(90deg, #FF6600, #0044AA);"></div>
          <h3 class="font-display font-bold text-xl text-frost mb-3">18 Months. Same as You.</h3>
          <p class="font-body text-sm text-frost-dim leading-relaxed">
            A LurraCore mine retrofit takes 18 months from contract to commissioning — exactly the construction timeline of a hyperscale data center. You sign the LurraPDA when you break ground. Power is commissioned when your racks go live.
          </p>
        </div>

        <!-- 3 -->
        <div class="bg-void p-8 md:p-10">
          <div class="w-10 h-1 mb-6" style="background: linear-gradient(90deg, #FF6600, #0044AA);"></div>
          <h3 class="font-display font-bold text-xl text-frost mb-3">70–100 MW. Firm. Daily.</h3>
          <p class="font-body text-sm text-frost-dim leading-relaxed">
            LurraCore dispatches 70–100 MW of firm baseload power during your peak operating window — 14 to 16 continuous hours per day. Not intermittent. Not curtailed. Firm, schedulable, behind-the-meter power your operators can count on.
          </p>
        </div>

        <!-- 4 -->
        <div class="bg-void p-8 md:p-10">
          <div class="w-10 h-1 mb-6" style="background: linear-gradient(90deg, #0044AA, #FF6600);"></div>
          <h3 class="font-display font-bold text-xl text-frost mb-3">A Recharge Strategy That Works</h3>
          <p class="font-body text-sm text-frost-dim leading-relaxed">
            During a 10-hour overnight window, LurraCharge recharges the system through negotiated power purchase agreements targeting off-peak and curtailed generation. The input cost structure is what makes the economics work — and what keeps your power price locked for 20 years.
          </p>
        </div>

        <!-- 5 -->
        <div class="bg-void p-8 md:p-10 md:col-span-2 lg:col-span-2">
          <div class="w-10 h-1 mb-6" style="background: linear-gradient(90deg, #0044AA, #FF6600);"></div>
          <h3 class="font-display font-bold text-xl text-frost mb-4">Why Behind-the-Meter Changes Everything</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-4">
              <div class="flex gap-3 items-start">
                <span class="w-1.5 h-1.5 bg-royal-light rounded-full mt-2 shrink-0"></span>
                <p class="font-body text-sm text-frost-dim">No interconnection queue — power delivered directly to your load</p>
              </div>
              <div class="flex gap-3 items-start">
                <span class="w-1.5 h-1.5 bg-royal-light rounded-full mt-2 shrink-0"></span>
                <p class="font-body text-sm text-frost-dim">No transmission charges — you pay for generation, not delivery</p>
              </div>
              <div class="flex gap-3 items-start">
                <span class="w-1.5 h-1.5 bg-royal-light rounded-full mt-2 shrink-0"></span>
                <p class="font-body text-sm text-frost-dim">No fuel price exposure — locked rate for the full contract term</p>
              </div>
            </div>
            <div class="space-y-4">
              <div class="flex gap-3 items-start">
                <span class="w-1.5 h-1.5 bg-orange-400 rounded-full mt-2 shrink-0"></span>
                <p class="font-body text-sm text-frost-dim">No ESG conflict — zero-emission dispatchable power</p>
              </div>
              <div class="flex gap-3 items-start">
                <span class="w-1.5 h-1.5 bg-orange-400 rounded-full mt-2 shrink-0"></span>
                <p class="font-body text-sm text-frost-dim">20-year price certainty under a take-or-pay LurraPDA</p>
              </div>
              <div class="flex gap-3 items-start">
                <span class="w-1.5 h-1.5 bg-orange-400 rounded-full mt-2 shrink-0"></span>
                <p class="font-body text-sm text-frost-dim">Complementary to gas — serves markets where gas cannot due to ESG mandates or permitting constraints</p>
              </div>
            </div>
          </div>
        </div>

      </div>

      <!-- Pull quote -->
      <div class="mt-12 border-l-4 pl-8" style="border-color: #FF6600;">
        <p class="font-display font-bold text-xl md:text-2xl text-frost leading-snug">
          "We are not competing with the grid. We are serving the market the grid cannot reach — on the timeline the grid cannot meet."
        </p>
      </div>

    </div>
  </section>

  <!-- Platform Layers -->
  {layers.map((layer, i) => (
    <section class={`py-20 px-8 md:px-12 max-w-7xl mx-auto reveal ${i < layers.length - 1 ? 'border-b border-rule' : ''}`}>
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8 items-start">
        <!-- Number -->
        <div class="md:col-span-1">
          <span class="font-display font-bold text-5xl text-rule">{layer.num}</span>
        </div>
        <!-- Content -->
        <div class="md:col-span-5">
          <p class="font-body text-xs tracking-[0.25em] uppercase eyebrow-over-image mb-3">{layer.tag}</p>
          <h2 class="font-display font-bold text-3xl text-frost mb-6 flex items-center gap-3">
            {layer.name}
            {layer.patent && (
              <span class="text-xs font-body tracking-widest uppercase px-2 py-1 align-middle" style="border:1px solid #FF6600;color:#FF6600;">Patent Pending</span>
            )}
          </h2>
          <p class="font-body text-base text-frost-dim leading-relaxed">{layer.body}</p>
        </div>
        <!-- Detail -->
        <div class="md:col-span-5 md:col-start-8">
          <div class="border-l-2 border-royal pl-6">
            <p class="font-body text-sm text-frost-dim leading-relaxed">{layer.detail}</p>
            {layer.patent && (
              <a
                href="https://zenodo.org/doi/10.5281/zenodo.20045602"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block mt-4 font-body text-xs tracking-widest uppercase text-royal hover:text-royal-light transition-colors duration-300"
              >
                View Prior Art Publication ↗
              </a>
            )}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Physics note -->
  <section class="py-20 px-8 md:px-12 reveal section-orange-accent w-full">
    <div class="bg-rule p-10 md:p-14">
      <p class="eyebrow">The Physics</p>
      <p class="font-display font-bold text-xl md:text-2xl text-frost leading-snug max-w-3xl">
        LurraCore is a storage and dispatch machine — not perpetual motion. Every megawatt delivered to the data center requires approximately 1.25 MW of LurraCharge input at 80% round-trip efficiency. The business works because the input-to-output cost spread is four to five times.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-8 md:px-12 text-center reveal">
    <a
      href="/sites"
      class="inline-block font-display font-bold text-sm tracking-widest uppercase px-10 py-4 bg-royal text-frost hover:bg-royal-light transition-colors duration-300"
    >
      View the Site Portfolio →
    </a>
  </section>

  <Footer />
</Base>
