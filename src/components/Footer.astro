---

<footer class="border-t border-rule px-6 md:px-12 py-12 md:py-16">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-10">
      
      <!-- Logo -->
      <div>
        <a href="/" class="flex items-center gap-3 no-underline mb-4">
          <svg width="14" height="22" viewBox="0 0 18 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <polygon points="18,0 15,0 0,14 4,14 8,14 18,0" fill="#0044AA"/>
            <polygon points="2,14 6,14 8,28 16,14 10,14" fill="#FF6600"/>
          </svg>
          <span class="font-display font-bold text-xl tracking-[0.25em] text-frost">LURRA</span><span class="font-display font-bold text-xl tracking-[0.25em] text-royal">GRID</span>
        </a>
        <p class="font-body text-sm text-frost-dim italic max-w-xs leading-relaxed">
          Lurra — earth goddess of the Basque people — lives underground in the caves. She holds amazing treasures in her bosom.
        </p>
      </div>
      
      <!-- Nav links -->
      <div class="flex flex-col gap-3">
        <a href="/platform" class="font-body text-sm tracking-widest uppercase text-frost-dim hover:text-frost transition-colors duration-300">Platform</a>
        <a href="/datacenter" class="font-body text-sm tracking-widest uppercase text-frost-dim hover:text-frost transition-colors duration-300">Data Centers</a>
        <a href="/sites" class="font-body text-sm tracking-widest uppercase text-frost-dim hover:text-frost transition-colors duration-300">Sites</a>
        <a href="/research" class="font-body text-sm tracking-widest uppercase text-frost-dim hover:text-frost transition-colors duration-300">Research</a>
        <a href="/about" class="font-body text-sm tracking-widest uppercase text-frost-dim hover:text-frost transition-colors duration-300">About</a>
      </div>
      
      <!-- Contact -->
      <div class="flex flex-col gap-3">
        <p class="font-body text-xs tracking-widest uppercase text-frost-dim mb-1">Partner Inquiries</p>
        <a href="/contact" class="font-display font-bold text-sm tracking-widest uppercase px-6 py-3 bg-royal text-frost hover:bg-royal-light transition-colors duration-300 inline-block mt-2">Contact Form →</a>
      </div>
    </div>
    
    <div class="mt-16 pt-8 border-t border-rule flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="font-body text-xs text-frost-dim tracking-widest uppercase">
        Powering the AI Era from the Ground Down.
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="font-body text-xs text-frost-dim hover:text-frost transition-colors duration-300">Privacy</a>
        <a href="/terms" class="font-body text-xs text-frost-dim hover:text-frost transition-colors duration-300">Terms</a>
        <span class="font-body text-xs text-frost-dim">© 2026 LurraGrid</span>
      </div>
    </div>
  </div>
</footer>
