---
---

<div class="hero-svg-container w-full max-w-2xl mx-auto">
  <svg
    viewBox="0 0 600 760"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-auto svg-draw"
    role="img"
    aria-label="LurraCore underground cross-section diagram"
  >
    <defs>
      <pattern id="grid" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#0044AA" stroke-width="0.3" opacity="0.15"/>
      </pattern>
      <linearGradient id="shaftGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#0044AA" stop-opacity="0.6"/>
        <stop offset="100%" stop-color="#0044AA" stop-opacity="0.1"/>
      </linearGradient>
      <linearGradient id="waterTop" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#0055CC" stop-opacity="0.9"/>
        <stop offset="100%" stop-color="#003388" stop-opacity="0.5"/>
      </linearGradient>
      <linearGradient id="waterBot" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#0044AA" stop-opacity="0.5"/>
        <stop offset="100%" stop-color="#002266" stop-opacity="0.25"/>
      </linearGradient>
      <clipPath id="leftShaftClip">
        <rect x="160" y="190" width="30" height="300"/>
      </clipPath>
      <clipPath id="penstockClip">
        <rect x="168" y="565" width="14" height="50"/>
      </clipPath>
      <!-- Orange glow filter for lightning bolt -->
      <filter id="boltGlow" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur"/>
        <feMerge>
          <feMergeNode in="blur"/>
          <feMergeNode in="SourceGraphic"/>
        </feMerge>
      </filter>
    </defs>

    <rect width="600" height="760" fill="url(#grid)" opacity="0.5"/>

    <!-- SURFACE LINE -->
    <line x1="0" y1="60" x2="600" y2="60" stroke="#F5F7FA" stroke-width="1.5" class="delay-1"/>
    <text x="10" y="52" fill="#A0A8B5" font-size="9" font-family="Inter,sans-serif" letter-spacing="2"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 0.3s ease forwards;opacity:0">SURFACE</text>

    <!-- Headframe LEFT -->
    <line x1="175" y1="10" x2="175" y2="60" stroke="#0055CC" stroke-width="1.5" class="delay-1"/>
    <line x1="150" y1="60" x2="200" y2="60" stroke="#0055CC" stroke-width="2" class="delay-1"/>
    <line x1="160" y1="10" x2="175" y2="30" stroke="#0055CC" stroke-width="1" class="delay-1"/>
    <line x1="190" y1="10" x2="175" y2="30" stroke="#0055CC" stroke-width="1" class="delay-1"/>
    <text x="110" y="8" fill="#A0A8B5" font-size="8" font-family="Inter,sans-serif" letter-spacing="1.5"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 0.4s ease forwards;opacity:0">INTAKE SHAFT</text>

    <!-- Headframe RIGHT -->
    <line x1="415" y1="10" x2="415" y2="60" stroke="#0055CC" stroke-width="1.5" class="delay-2"/>
    <line x1="390" y1="60" x2="440" y2="60" stroke="#0055CC" stroke-width="2" class="delay-2"/>
    <line x1="400" y1="10" x2="415" y2="30" stroke="#0055CC" stroke-width="1" class="delay-2"/>
    <line x1="430" y1="10" x2="415" y2="30" stroke="#0055CC" stroke-width="1" class="delay-2"/>
    <text x="355" y="8" fill="#A0A8B5" font-size="8" font-family="Inter,sans-serif" letter-spacing="1.5"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 0.4s ease forwards;opacity:0">RETURN SHAFT</text>

    <!-- UPPER RESERVOIR -->
    <rect x="80" y="62" width="340" height="128" rx="3" fill="#0044AA" fill-opacity="0.10" stroke="#0044AA" stroke-width="1.5" class="delay-2"/>
    <rect x="82" y="80" width="336" height="108" rx="2" fill="url(#waterTop)" fill-opacity="0.65" class="delay-3"/>
    <line x1="82" y1="80" x2="418" y2="80" stroke="#0055CC" stroke-width="1.2" stroke-dasharray="5,3" class="water-surface"/>
    <text x="215" y="77" fill="#A0A8B5" font-size="8" font-family="Inter,sans-serif" letter-spacing="2"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 1.2s ease forwards;opacity:0">UPPER RESERVOIR</text>
    <text x="225" y="135" fill="#0066EE" font-size="10" font-family="Inter,sans-serif" letter-spacing="1"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 1.3s ease forwards;opacity:0">700,000 m³</text>

    <!-- LEFT SHAFT -->
    <rect x="160" y="190" width="30" height="300" fill="url(#shaftGrad)" stroke="#0044AA" stroke-width="1" class="delay-3"/>
    <line x1="130" y1="290" x2="160" y2="290" stroke="#0044AA" stroke-width="0.5" class="delay-3"/>
    <text x="72" y="294" fill="#A0A8B5" font-size="8" font-family="Inter,sans-serif" letter-spacing="1"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 1.4s ease forwards;opacity:0">1,500 ft</text>
    <line x1="130" y1="390" x2="160" y2="390" stroke="#0044AA" stroke-width="0.5" class="delay-4"/>
    <text x="72" y="394" fill="#A0A8B5" font-size="8" font-family="Inter,sans-serif" letter-spacing="1"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 1.6s ease forwards;opacity:0">2,500 ft</text>

    <!-- WATER DROPLETS in left shaft -->
    <g clip-path="url(#leftShaftClip)" style="opacity:0;animation:fadeIn 0s 3s ease forwards">
      <circle cx="172" cy="220" r="3"   fill="#0055CC" fill-opacity="0.8" class="drop drop-1"/>
      <circle cx="178" cy="270" r="2.5" fill="#0066DD" fill-opacity="0.7" class="drop drop-2"/>
      <circle cx="170" cy="330" r="3"   fill="#0055CC" fill-opacity="0.8" class="drop drop-3"/>
      <circle cx="180" cy="380" r="2"   fill="#0066DD" fill-opacity="0.6" class="drop drop-4"/>
      <circle cx="174" cy="430" r="3"   fill="#0055CC" fill-opacity="0.8" class="drop drop-5"/>
      <rect x="171" y="240" width="2" height="12" fill="#0055CC" fill-opacity="0.4" class="drop drop-2"/>
      <rect x="177" y="300" width="2" height="10" fill="#0055CC" fill-opacity="0.4" class="drop drop-3"/>
      <rect x="173" y="360" width="2" height="14" fill="#0055CC" fill-opacity="0.4" class="drop drop-4"/>
      <rect x="179" y="410" width="2" height="12" fill="#0055CC" fill-opacity="0.4" class="drop drop-5"/>
    </g>

    <!-- PENSTOCK water -->
    <g clip-path="url(#penstockClip)" style="opacity:0;animation:fadeIn 0s 3.5s ease forwards">
      <circle cx="175" cy="575" r="3"   fill="#0055CC" fill-opacity="0.8" class="drop drop-penstock-1"/>
      <circle cx="175" cy="590" r="2.5" fill="#0066DD" fill-opacity="0.7" class="drop drop-penstock-2"/>
      <rect x="173" y="580" width="2" height="10" fill="#0055CC" fill-opacity="0.4" class="drop drop-penstock-1"/>
    </g>

    <!-- RIGHT SHAFT -->
    <rect x="400" y="190" width="30" height="490" fill="url(#shaftGrad)" stroke="#0044AA" stroke-width="1" class="delay-3"/>

    <!-- TURBINE BOX -->
    <rect x="120" y="490" width="190" height="75" rx="6" fill="#0044AA" fill-opacity="0.18" stroke="#0055CC" stroke-width="1.5" class="delay-5"/>
    <!-- Static turbine ring -->
    <circle cx="215" cy="527" r="22" fill="#000814" fill-opacity="0.6" stroke="#0044AA" stroke-width="1" class="delay-5"/>
    <!-- Static blades — no animation, just structure -->
    <line x1="215" y1="508" x2="215" y2="546" stroke="#0044AA" stroke-width="1" class="delay-5"/>
    <line x1="196" y1="527" x2="234" y2="527" stroke="#0044AA" stroke-width="1" class="delay-5"/>
    <line x1="202" y1="514" x2="228" y2="540" stroke="#0044AA" stroke-width="0.7" class="delay-5"/>
    <line x1="202" y1="540" x2="228" y2="514" stroke="#0044AA" stroke-width="0.7" class="delay-5"/>
    <!-- PULSATING ORANGE LIGHTNING BOLT centered on turbine -->
    <path d="M 220 508 L 210 526 L 218 526 L 210 546 L 222 524 L 214 524 Z"
      fill="#FF6600" filter="url(#boltGlow)" class="bolt-pulse"
      style="opacity:0;animation:fadeIn 0s 3.2s ease forwards,boltPulse 1.6s 3.2s ease-in-out infinite"/>
    <text x="145" y="484" fill="#A0A8B5" font-size="8" font-family="Inter,sans-serif" letter-spacing="1.5"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 2.0s ease forwards;opacity:0">TURBINE / PUMP</text>

    <!-- Penstock line -->
    <line x1="175" y1="565" x2="175" y2="612" stroke="#0055CC" stroke-width="3" class="delay-5"/>

    <!-- Power output line -->
    <line x1="310" y1="527" x2="480" y2="527" stroke="#F5F7FA" stroke-width="1" stroke-dasharray="5,3" class="delay-5"/>
    <line x1="480" y1="527" x2="480" y2="440" stroke="#F5F7FA" stroke-width="1" stroke-dasharray="5,3" class="delay-5"/>
    <circle cx="480" cy="424" r="16" fill="none" stroke="#FF6600" stroke-width="1.5" class="delay-6"/>
    <!-- Orange bolt on BTM output too -->
    <path d="M 484 414 L 477 424 L 482 424 L 476 434 L 485 422 L 480 422 Z"
      fill="#FF6600" filter="url(#boltGlow)"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0s 2.5s ease forwards,boltPulse 1.6s 2.8s ease-in-out infinite;opacity:0"/>
    <text x="447" y="408" fill="#A0A8B5" font-size="7" font-family="Inter,sans-serif" letter-spacing="1.5"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 2.3s ease forwards;opacity:0">BTM OUTPUT</text>

    <!-- LOWER RESERVOIR -->
    <rect x="80" y="612" width="340" height="118" rx="3" fill="#0044AA" fill-opacity="0.08" stroke="#0044AA" stroke-width="1.5" class="delay-6"/>
    <rect x="82" y="670" width="336" height="58" rx="2" fill="url(#waterBot)" fill-opacity="0.5" class="delay-6"/>
    <line x1="82" y1="670" x2="418" y2="670" stroke="#0044AA" stroke-width="1" stroke-dasharray="4,3" class="water-surface-slow"/>
    <text x="215" y="750" fill="#A0A8B5" font-size="8" font-family="Inter,sans-serif" letter-spacing="2"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 2.4s ease forwards;opacity:0">LOWER RESERVOIR</text>

    <!-- Depth bar -->
    <line x1="555" y1="60" x2="555" y2="730" stroke="#0044AA" stroke-width="0.5" class="delay-2"/>
    <line x1="545" y1="60" x2="565" y2="60" stroke="#0044AA" stroke-width="0.5" class="delay-2"/>
    <line x1="545" y1="730" x2="565" y2="730" stroke="#0044AA" stroke-width="0.5" class="delay-6"/>
    <text x="561" y="400" fill="#A0A8B5" font-size="7" font-family="Inter,sans-serif" letter-spacing="1"
      transform="rotate(90,561,400)"
      style="stroke-dasharray:none;stroke-dashoffset:0;animation:fadeIn 0.5s 2.0s ease forwards;opacity:0">3,500 ft DEPTH</text>
  </svg>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* Orange bolt pulse — breathes in and out */
  @keyframes boltPulse {
    0%, 100% { opacity: 0.4; filter: drop-shadow(0 0 2px #FF6600); }
    50%       { opacity: 1.0; filter: drop-shadow(0 0 8px #FF8800) drop-shadow(0 0 16px #FF6600); }
  }

  /* Water droplets falling */
  @keyframes dropFall {
    0%   { transform: translateY(0);    opacity: 0.9; }
    80%  { transform: translateY(270px); opacity: 0.6; }
    100% { transform: translateY(300px); opacity: 0; }
  }

  .drop { animation: dropFall 2.4s ease-in infinite; }
  .drop-1 { animation-delay: 3.0s; }
  .drop-2 { animation-delay: 3.5s; }
  .drop-3 { animation-delay: 4.0s; }
  .drop-4 { animation-delay: 4.5s; }
  .drop-5 { animation-delay: 5.0s; }
  .drop-penstock-1 { animation: dropFall 1.2s ease-in infinite; animation-delay: 3.5s; }
  .drop-penstock-2 { animation: dropFall 1.2s ease-in infinite; animation-delay: 3.9s; }

  /* Water surface shimmer */
  @keyframes shimmer {
    0%   { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: -30; }
  }
  .water-surface      { opacity:0; animation: fadeIn 0.5s 1.5s ease forwards, shimmer 2s 2s linear infinite; }
  .water-surface-slow { opacity:0; animation: fadeIn 0.5s 2.5s ease forwards, shimmer 3s 3s linear infinite; }
</style>
